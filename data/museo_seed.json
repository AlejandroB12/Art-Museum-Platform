{
  "autores": [
    { "_id": 1, "nombre": "Ai-Da", "apellido": "Robot", "fecha_nacimiento": "2019-02-01", "fotografia": "/images/authors/AiDARobot.jpg", "biografia": "Ai-Da es el primer robot artista ultrarrrealista del mundo. Creada en Oxford, Reino Unido, utiliza inteligencia artificial para crear dibujos, pinturas y esculturas. Su obra explora la relación entre tecnología, creatividad y conciencia artificial.", "nacionalidad": "Reino Unido" },
    { "_id": 2, "nombre": "Ai", "apellido": "Weiwei", "fecha_nacimiento": "1957-08-28", "fotografia": "/images/authors/AiWeiwei.jpg", "biografia": "Artista conceptual, activista y arquitecto chino. Conocido por su crítica al gobierno chino y su defensa de los derechos humanos. Su obra abarca escultura, instalación, fotografía y cine documental.", "nacionalidad": "China" },
    { "_id": 3, "nombre": "Anish", "apellido": "Kapoor", "fecha_nacimiento": "1954-03-12", "fotografia": "/images/authors/AnishKapoor.jpg", "biografia": "Escultor británico-indio famoso por sus instalaciones a gran escala y esculturas monumentales. Su obra más conocida es 'Cloud Gate' en Chicago. Explora el vacío, la luz y el color, especialmente con su exclusivo Vantablack.", "nacionalidad": "Reino Unido" },
    { "_id": 4, "nombre": "Carlos", "apellido": "Cruz-Diez", "fecha_nacimiento": "1923-08-17", "fotografia": "/images/authors/CarlosCruzDiez.jpg", "biografia": "Pintor y escultor venezolano, uno de los máximos representantes del arte cinético y óptico. Su obra se centra en el estudio del color como realidad autónoma en constante transformación.", "nacionalidad": "Venezuela" },
    { "_id": 5, "nombre": "Cindy", "apellido": "Sherman", "fecha_nacimiento": "1954-01-19", "fotografia": "/images/authors/CindySherman.jpg", "biografia": "Fotógrafa y cineasta estadounidense conocida por sus autorretratos conceptuales que exploran la identidad, el género y los estereotipos sociales. Su serie 'Untitled Film Stills' es icónica.", "nacionalidad": "Estados Unidos" },
    { "_id": 6, "nombre": "Damien", "apellido": "Hirst", "fecha_nacimiento": "1965-06-07", "fotografia": "/images/authors/DamienHirst.jpg", "biografia": "Artista británico líder del grupo Young British Artists. Conocido por obras controvertidas como tiburones en formol, pastillas, calaveras de diamante y puntos multicolores. Explora la muerte y la mortalidad.", "nacionalidad": "Reino Unido" },
    { "_id": 7, "nombre": "Doris", "apellido": "Salcedo", "fecha_nacimiento": "1958-01-01", "fotografia": "/images/authors/DorisSalcedo.jpg", "biografia": "Escultora colombiana reconocida por sus instalaciones que abordan la violencia política y el trauma social. Crea obras con muebles, ropa y objetos cotidianos intervenidos con hormigón.", "nacionalidad": "Colombia" },
    { "_id": 8, "nombre": "Edmund", "apellido": "de Waal", "fecha_nacimiento": "1964-01-02", "fotografia": "/images/authors/EdmunddeWaal.jpg", "biografia": "Ceramista y escritor británico, autor del bestseller 'La liebre con ojos de ámbar'. Sus obras minimalistas exploran la relación entre objetos, memoria y lugar, utilizando porcelana blanca.", "nacionalidad": "Reino Unido" },
    { "_id": 9, "nombre": "Gabriel", "apellido": "Orozco", "fecha_nacimiento": "1962-04-27", "fotografia": "/images/authors/GabrielOrozco.jpg", "biografia": "Artista conceptual mexicano conocido por sus fotografías, esculturas e instalaciones que transforman objetos cotidianos en experiencias poéticas. Explora el azar, el juego y la geografía.", "nacionalidad": "México" },
    { "_id": 10, "nombre": "Grayson", "apellido": "Perry", "fecha_nacimiento": "1960-03-24", "fotografia": "/images/authors/GraysonPerry.jpg", "biografia": "Ceramista, bordador y artista británico conocido por sus jarrones decorativos que narran historias controvertidas sobre clase, género y sexualidad. Viste frecuentemente como su alter ego femenino 'Claire'.", "nacionalidad": "Reino Unido" },
    { "_id": 11, "nombre": "Jeff", "apellido": "Koons", "fecha_nacimiento": "1955-01-21", "fotografia": "/images/authors/JeffKoons.jpg", "biografia": "Artista estadounidense famoso por sus esculturas brillantes de animales globo y objetos kitsch. Su obra explora el consumismo, la cultura pop y lo camp. Posee el récord de obra más cara de un artista vivo.", "nacionalidad": "Estados Unidos" },
    { "_id": 12, "nombre": "Kiki", "apellido": "Smith", "fecha_nacimiento": "1954-01-18", "fotografia": "/images/authors/KikiSmith.jpg", "biografia": "Artista estadounidense nacida en Alemania que trabaja escultura, grabado y dibujo. Aborda temas como el cuerpo humano, la mortalidad, la naturaleza y la espiritualidad con materiales orgánicos.", "nacionalidad": "Estados Unidos" },
    { "_id": 13, "nombre": "Marina", "apellido": "Abramović", "fecha_nacimiento": "1946-11-30", "fotografia": "/images/authors/MarinaAbramović.jpg", "biografia": "Pionera del arte performance, conocida por sus obras de resistencia física y mental. Su pieza 'The Artist is Present' en el MoMA la estableció como la 'abuela del arte performance'.", "nacionalidad": "Serbia y Montenegro" },
    { "_id": 14, "nombre": "Ólafur", "apellido": "Elíasson", "fecha_nacimiento": "1967-02-05", "fotografia": "/images/authors/ÓlafurElíasson.jpg", "biografia": "Artista danés-islandés conocido por instalaciones de gran escala que utilizan elementos naturales como luz, agua y niebla. Su obra 'The Weather Project' en la Tate Modern es legendaria.", "nacionalidad": "Islandia" },
    { "_id": 15, "nombre": "Takashi", "apellido": "Murakami", "fecha_nacimiento": "1962-02-01", "fotografia": "/images/authors/TakashiMurakami.jpg", "biografia": "Artista japonés fundador del movimiento Superflat, que fusiona el arte tradicional japonés con la cultura pop contemporánea. Conocido por sus flores sonrientes y colaboraciones con marcas de lujo.", "nacionalidad": "Japón" },
    { "_id": 16, "nombre": "Theaster", "apellido": "Gates", "fecha_nacimiento": "1973-08-28", "fotografia": "/images/authors/TheasterGates.jpg", "biografia": "Artista, músico y urbanista estadounidense. Transforma edificios abandonados en espacios culturales. Su obra aborda la historia afroamericana, la religión, la música y el desarrollo comunitario.", "nacionalidad": "Estados Unidos" },
    { "_id": 17, "nombre": "Vik", "apellido": "Muniz", "fecha_nacimiento": "1961-12-20", "fotografia": "/images/authors/VikMuniz.jpg", "biografia": "Artista conceptual brasileño conocido por recrear obras maestras con materiales inusuales como chocolate, basura o juguetes. Su documental 'Waste Land' fue nominado al Oscar.", "nacionalidad": "Brasil" },
    { "_id": 18, "nombre": "Wallace", "apellido": "Chan", "fecha_nacimiento": "1956-01-01", "fotografia": "/images/authors/WallaceChan.jpg", "biografia": "Artista hongkonés conocido por sus esculturas cinéticas que utilizan máquinas para explorar la relación entre cuerpo, tecnología y sociedad en el contexto asiático contemporáneo.", "nacionalidad": "Hong Kong" },
    { "_id": 19, "nombre": "Yayoi", "apellido": "Kusama", "fecha_nacimiento": "1929-03-22", "fotografia": "/images/authors/YayoiKusama.jpg", "biografia": "Artista japonesa conocida por sus obras con lunares infinitos, calabazas y espejos. Vive voluntariamente en un hospital psiquiátrico desde 1977. Su serie 'Infinity Mirror Rooms' es mundialmente famosa.", "nacionalidad": "Japón" },
    { "_id": 20, "nombre": "Zeng", "apellido": "Fanzhi", "fecha_nacimiento": "1964-01-01", "fotografia": "/images/authors/ZengFanzhi.jpg", "biografia": "Pintor chino contemporáneo famoso por sus retratos expresionistas con máscaras y sus series abstractas 'Hospital' y 'Máscara'. Refleja la ansiedad y alienación en la China moderna.", "nacionalidad": "China" }
  ],
